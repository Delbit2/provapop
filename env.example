# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Database Configuration (PostgreSQL)
POSTGRES_USER=enem_user
POSTGRES_PASSWORD=enem_password
POSTGRES_DB=enem_brasil
POSTGRES_PORT=5432

# Database URL (automatically constructed from above, or set manually)
# DATABASE_URL=postgresql://enem_user:enem_password@db:5432/enem_brasil

# Backend Port
BACKEND_PORT=5000

# Google Sheets Configuration
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SHEETS_WORKSHEET_NAME=Ranking
# GOOGLE_SHEETS_CREDENTIALS_FILE is mounted as volume in docker-compose.yml

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:80,http://localhost
